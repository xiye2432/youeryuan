.profile-setup-page{background:-webkit-gradient(linear,left top,left bottom,from(#f6f8fb),to(#eef3f8));background:-webkit-linear-gradient(top,#f6f8fb,#eef3f8);background:linear-gradient(180deg,#f6f8fb,#eef3f8);-webkit-box-sizing:border-box;box-sizing:border-box;min-height:100vh;padding:32rpx}.setup-card{background:#fff;border-radius:28rpx;-webkit-box-shadow:0 16rpx 48rpx rgba(15,23,42,.08);box-shadow:0 16rpx 48rpx rgba(15,23,42,.08);padding:36rpx 28rpx}.setup-title{color:#0f172a;display:block;font-size:40rpx;font-weight:700}.setup-desc{color:#475569;display:block;font-size:26rpx;line-height:1.7;margin-top:16rpx}.form-section{margin-top:36rpx}.section-label{color:#1e293b;display:block;font-size:28rpx;font-weight:600;margin-bottom:20rpx}.option-grid{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:16rpx}.option-item{background:#f8fafc;border:2rpx solid #e2e8f0;border-radius:18rpx;-webkit-box-sizing:border-box;box-sizing:border-box;color:#334155;font-size:26rpx;min-width:180rpx;padding:18rpx 24rpx;text-align:center}.option-item.active{background:#0f766e;border-color:#0f766e;color:#fff}.submit-btn{-ms-flex-align:center;-ms-flex-pack:center;-webkit-align-items:center;align-items:center;background:#0f766e;border-radius:22rpx;color:#fff;display:-webkit-flex;display:-ms-flexbox;display:flex;font-size:30rpx;font-weight:600;height:88rpx;-webkit-justify-content:center;justify-content:center;margin-top:44rpx}.submit-btn.disabled{background:#94a3b8}.helper-text{color:#64748b;display:block;font-size:24rpx;margin-top:16rpx}